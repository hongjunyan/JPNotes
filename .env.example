# ---- 對外設定 ----
# 網站對外埠號（瀏覽 http://localhost:APP_PORT）
APP_PORT=8080

# ---- 後端 ----
# 單張圖片上傳上限（MB）
MAX_UPLOAD_MB=10

# 所有資料（SQLite、圖片、jamdict 字典）集中於一個資料夾：
#   本機開發預設 <repo>/db_data，docker 由 compose 設 DATA_DIR=/app/data 並掛載 ./db_data
# 個別路徑（DATABASE_URL / IMAGE_DIR / JAMDICT_DB）留空會自動從 DATA_DIR 衍生，
# 需要時才個別覆寫：
# DATA_DIR=./db_data
# DATABASE_URL=sqlite:///./db_data/jpnotes.db
# IMAGE_DIR=./db_data/images
# JAMDICT_DB=./db_data/jamdict/jamdict.db
